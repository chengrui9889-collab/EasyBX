# ============================================
# EasyBX 环境变量配置模板
# 复制此文件为 .env 并填入实际值
# ============================================

# 数据库连接 (SQLite 文件路径)
DATABASE_URL=sqlite:///../data/easybx.db

# JWT 密钥 (生产环境请使用强随机字符串)
JWT_SECRET=change-me-to-a-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# 文件上传目录
UPLOAD_DIR=./uploads

# 服务端口
SERVER_PORT=0220

# OCR 开关 (true/false, 关闭后 OCR 将返回模拟结果)
OCR_ENABLED=true

# 文件上传限制 (MB)
MAX_UPLOAD_SIZE_MB=10

# ============================================
# 生产环境部署配置
# ============================================

# CORS 允许的前端域名 (逗号分隔，部署到 Vercel 后要添加 Vercel 域名)
# 例: CORS_ORIGINS=https://easybx.vercel.app,https://your-custom-domain.com
# CORS_ORIGINS=http://localhost:5180,http://127.0.0.1:5180
